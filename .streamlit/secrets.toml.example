# Copy this file to .streamlit/secrets.toml and fill in your values.
# Never commit secrets.toml — it is already in .gitignore.

# ── Anthropic (required for AI Forecast page) ─────────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-..."

# ── Premium tier ──────────────────────────────────────────────────────────────
# Comma-separated list of one-time access codes you issue after Stripe payment.
# Generate random codes with: python -c "import secrets; print(secrets.token_urlsafe(16))"
PREMIUM_CODES = "code-abc123,code-def456"

# Stripe Payment Link URL (create at https://dashboard.stripe.com/payment-links)
STRIPE_PAYMENT_LINK = "https://buy.stripe.com/YOUR_PAYMENT_LINK"

# ── Affiliate (optional — override placeholder URLs) ──────────────────────────
# Set these to your actual referral URLs to earn commissions.
# If unset, the placeholder URLs in affiliate.py are used.
# WEBULL_REF_URL  = "https://a.webull.com/i/YOUR_CODE"
# IBKR_REF_URL    = "https://ibkr.com/referral/YOUR_CODE"
# TV_AFF_URL      = "https://www.tradingview.com/?aff_id=YOUR_ID"
